// SQLite datasource for development. Switch to postgresql for production:
//   provider = "postgresql"
//   url      = env("DATABASE_URL")

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(cuid())
  username  String   @unique
  email     String   @unique
  password  String
  createdAt DateTime @default(now())
  matches   MatchParticipant[]
}

model Question {
  id         String @id @default(cuid())
  text       String
  options    String // JSON string of string[] (SQLite doesn't support Json natively)
  answer     String
  category   String
  difficulty String
  source     String @default("manual") // "opentdb" | "manual"
}

model Match {
  id           String             @id @default(cuid())
  roomCode     String
  category     String
  createdAt    DateTime           @default(now())
  participants MatchParticipant[]
}

model MatchParticipant {
  id      String @id @default(cuid())
  userId  String
  matchId String
  score   Int
  rank    Int
  user    User   @relation(fields: [userId], references: [id])
  match   Match  @relation(fields: [matchId], references: [id])
}
